<%- include('../partials/header', { user: user }) %>

<main style="display:flex; justify-content:center; align-items:center; height:80vh;">
  <form action="/auth/profile?_method=PATCH" method="POST" enctype="multipart/form-data" 
        style="display:flex; flex-direction:column; gap:10px; width:300px; padding:20px; border:1px solid #ccc; border-radius:8px;">
    
    <h2>Edit Profile</h2>

    
    <% if (typeof error !== 'undefined' && error) { %>
      <p style="color:red; text-align:center;"><%= error %></p>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <p style="color:green; text-align:center;"><%= success %></p>
    <% } %>

    
    <input type="text" name="name" placeholder="Display Name" value="<%= user.name %>" required>

    
    <input type="file" name="avatar">

   
    <div style="text-align:center;">
      <img src="<%= user.avatar || '/img/default-avatar.png' %>" 
           alt="Current Avatar" style="width:100px; height:100px; border-radius:50%; margin-top:10px;">
    </div>

    <button type="submit" style="padding:10px; background:#7289da; color:white; border:none; border-radius:5px; cursor:pointer;">
      Update Profile
    </button>

    <div style="text-align:center; margin-top:10px;">
      <a href="/chat" style="color:#7289da; text-decoration:underline;">Back to Chat</a>
    </div>
  </form>
</main>

<%- include('../partials/footer') %>