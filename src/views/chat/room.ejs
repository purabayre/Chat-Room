<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= room.name %> - ChatApp</title>
 
 <style>

  .message-wrapper {
    display: flex;
    flex-direction: column;
    position: relative;
    width: 100%;
  }

  
  .message-wrapper.own {
    align-items: flex-end;
  }

  .message-wrapper.other {
    align-items: flex-start;
  }

  .message-bubble {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border-radius: 15px;
    max-width: 70%;
    word-wrap: break-word;
  }

  
  .message-bubble.own {
    background: #7289da;
    color: white;
    flex-direction: row-reverse;
  }

 
  .message-bubble.other {
    background: #e0e0e0;
    color: black;
    flex-direction: row;
  }

 
  .message-wrapper s{
    font-size: 0.75rem;
    color: #666;
    margin-top: 2px;
  }

  .message-wrapper.own  {
    text-align: right;
  }

  .message-wrapper.other  {
    text-align: left;
  }

 
  .reactions-popup {
    display: flex;
    gap: 5px;
    position: absolute;
    top: -30px;
    background: #fff;
    padding: 4px 4px;
    border-radius: 10px;
    box-shadow: 0 0 5px rgba(0,0,0,0.2);
    opacity: 0;
    pointer-events: none;
    transition: 0.2s;
    z-index: 10;
  }

  .message-wrapper.own .reactions-popup {
    right: 0;
  }

  .message-wrapper.other .reactions-popup {
    left: 0;
  }

  .message-wrapper:hover .reactions-popup {
    opacity: 1;
    pointer-events: auto;
  }

  .reaction-btn {
    cursor: pointer;
    transition: transform 0.1s;
  }

  .reaction-btn:hover {
    transform: scale(1.2);
  }

 
  .reactions-display {
    margin-top: 4px;
    font-size: 0.8rem;
    color: #333;
    display: flex;
    gap: 6px;
  }

 
  .mention {
    background: #fffae6;
    color: #333;
    padding: 2px 5px;
    border-radius: 4px;
    font-weight: 600;
  }

  
  #mention-list {
    position: absolute;
    background: white;
    border: 1px solid #ccc;
    border-radius: 5px;
    display: none;
    z-index: 1000;
    max-height: 150px;
    overflow-y: auto;
    width: 200px;
  }

  #mention-list div {
    padding: 6px;
    cursor: pointer;
  }

  #mention-list div:hover {
    background: #f1f1f1;
  }


  #load-more {
    align-self: center;
    padding: 5px 10px;
    cursor: pointer;
    border: none;
    background: #ddd;
    border-radius: 5px;
  }

  #load-more:hover {
    background: #bdbcbc;
  }

</style>
</head>
<body>

  <%- include('../partials/header', { user: user }) %>

  <main style="padding:20px; max-width:800px; margin:auto;">
    
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
      <h1><%= room.name %></h1>
      <a href="/chat" style="padding:5px 10px; background:#43b581; color:white; border-radius:5px; text-decoration:none;">Back</a>
    </div>

    
    <div id="messages"
         style="border:1px solid #ccc; border-radius:5px; padding:10px; height:400px; overflow-y:auto; display:flex; flex-direction:column; gap:10px;">
      
      
      <button id="load-more" style="align-self:center; padding:5px 10px; margin-bottom:10px; cursor:pointer;">
        Load older messages
      </button>

      <% messages.forEach(msg => { %>
        const user = req.session.user;
       <% const isOwn = String(msg.sender?._id || msg.sender) === String(user.id);%>
          

       <div class="message-wrapper <%= isOwn ? 'own' : 'other'  %>" data-id="<%= msg._id %>">
          <div class="message-bubble <%= isOwn ? 'own' : 'other' %>">
            <% if (!isOwn) { %>
              <img src="<%= msg.sender?.avatarPath || '/img/default-avatar.png' %>" 
                   style="width:30px;height:30px;border-radius:50%;">
            <% } %>
            <span><%- msg.text.replace(/@(\w+)/g, '<span class="mention">@$1</span>') %></span>

            <% if (isOwn) { %>
              <img src="<%= user.avatar || '/img/default-avatar.png' %>" 
                   style="width:30px;height:30px;border-radius:50%;">
            <% } %>
          </div>
          <small 
            <%= msg.sender?.name || 'Unknown' %> • 
            <%= new Date(msg.createdAt).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) %>
          </small>

          

          <div class="reactions-popup">
            <span class="reaction-btn">👍</span>
            <span class="reaction-btn">❤️</span>
            <span class="reaction-btn">😂</span>
          </div>

          <div class="reactions-display">
            <% if (msg.reactions) { %>
              <% Object.entries(msg.reactions).forEach(([emoji, users]) => { %>
                <span><%= emoji %> <%= users.length %></span>
              <% }) %>
            <% } %>
          </div>
        </div>
      <% }) %>

    </div>

    <div id="typing" style="color:#666; font-style:italic; font-size: medium; margin-bottom:10px;"></div>

    <% if (user) { %>
      <form id="chat-form" style="display:flex; gap:10px; position:relative;">
        <input id="message-input" type="text" placeholder="Type a message..." required
               style="flex:1; padding:5px; border-radius:5px; border:1px solid #ccc;" autocomplete="off">

        <button type="submit"
                style="padding:5px 10px; background:#7289da; color:white; border:none; border-radius:5px;">
          Send
        </button>

        <div id="mention-list"></div>
      </form>
    <% } %>

  </main>

  <%- include('../partials/footer') %>

  <script src="/socket.io/socket.io.js"></script>

  <script>
    const socket = io();

    const roomId = "<%= room._id %>";
    const userId = "<%= user.id %>";

    const messagesDiv = document.getElementById('messages');
    const form = document.getElementById('chat-form');
    const input = document.getElementById('message-input');
    const typingDiv = document.getElementById('typing');
    const mentionList = document.getElementById('mention-list');
    const loadMoreBtn = document.getElementById('load-more');

    let usersInRoom = [];

    socket.emit("join-room", { roomId });
    socket.emit("get-room-users", roomId);

    socket.on('room-users', (users) => usersInRoom = users);

    socket.on('room-history', (messages) => {
      messagesDiv.innerHTML = '';
      messagesDiv.appendChild(loadMoreBtn);
      messages.forEach(msg => messagesDiv.appendChild(createMessageElement(msg)));
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
    });

    socket.on('new-message', (msg) => {
      messagesDiv.appendChild(createMessageElement(msg));
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
    });

    socket.on('mention-notification', ({ from, text }) => {
      alert(`${from} mentioned you: ${text}`);
    });

    socket.on('user-joined', ({ name }) => addSystem(`${name} joined`));
    socket.on('user-left', ({ name }) => addSystem(`${name} left`));

    socket.on('typing', ({ name }) => typingDiv.innerText = `${name} is typing...`);
    socket.on('stop-typing', () => typingDiv.innerText = '');

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text) return;
      socket.emit('new-message', { roomId, text });
      input.value = '';
      hideMentionList();
    });

    let timeout;
    input.addEventListener('input', () => {
      socket.emit('typing', roomId);
      clearTimeout(timeout);
      timeout = setTimeout(() => socket.emit('stop-typing', roomId), 1000);
      handleMentions();
    });

    function handleMentions() {
      const cursorPos = input.selectionStart;
      const textBefore = input.value.slice(0, cursorPos);
      const match = textBefore.match(/@(\w*)$/);

      if (!match) return hideMentionList();

      const search = match[1].toLowerCase();
      const matches = usersInRoom.filter(u => u.toLowerCase().startsWith(search));

      if (!matches.length) return hideMentionList();

      mentionList.innerHTML = '';
      matches.forEach(u => {
        const div = document.createElement('div');
        div.innerText = u;
        div.addEventListener('click', () => selectMention(u, match[0]));
        mentionList.appendChild(div);
      });

      const rect = input.getBoundingClientRect();
      mentionList.style.top = rect.bottom + window.scrollY + 'px';
      mentionList.style.left = rect.left + window.scrollX + 'px';
      mentionList.style.display = 'block';
    }

    function selectMention(user, trigger) {
      const start = input.value.lastIndexOf(trigger);
      input.value =
        input.value.slice(0, start) +
        '@' + user + ' ' +
        input.value.slice(start + trigger.length);

      input.focus();
      hideMentionList();
    }

    function hideMentionList() { mentionList.style.display = 'none'; }

    function addSystem(text) {
      const div = document.createElement('div');
      div.style.alignSelf = 'center';
      div.style.background = '#f1f1f1';
      div.style.color = '#555';
      div.style.padding = '6px 12px';
      div.style.borderRadius = '12px';
      div.style.fontSize = '0.8rem';
      div.style.margin = '5px 0';
      div.style.maxWidth = '60%';
      div.style.textAlign = 'center';
      div.innerText = text;
      messagesDiv.appendChild(div);
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }

    socket.on('message-reacted', ({ messageId, reactions }) => {
      const wrapper = messagesDiv.querySelector(`.message-wrapper[data-id='${messageId}']`);
      if (!wrapper) return;

      const display = wrapper.querySelector('.reactions-display');
      display.innerHTML = '';

      Object.entries(reactions).forEach(([emoji, users]) => {
        const span = document.createElement('span');
        span.innerText = `${emoji} ${users.length}`;
        display.appendChild(span);
      });
    });

    loadMoreBtn.addEventListener('click', () => {
      const firstMessage = messagesDiv.querySelector('.message-wrapper');
      if (!firstMessage) return;

      const beforeId = firstMessage.dataset.id;
      socket.emit('load-more', { roomId, beforeId });
    });

    socket.on('older-messages', (messages) => {
      if (!messages.length) {
        loadMoreBtn.disabled = true;
        loadMoreBtn.innerText = 'No more messages';
        return;
      }

      const scrollHeightBefore = messagesDiv.scrollHeight;

      messages.forEach(msg => {
        const wrapper = createMessageElement(msg);
        messagesDiv.insertBefore(wrapper, messagesDiv.children[1]);
      });

      messagesDiv.scrollTop = messagesDiv.scrollHeight - scrollHeightBefore;
    });

    function createMessageElement(msg) {
      const isOwn = msg.sender && msg.sender._id == userId;
console.log({userId})
      const wrapper = document.createElement('div');
      wrapper.classList.add('message-wrapper', isOwn ? 'own' : 'other');
      wrapper.dataset.id = msg._id;
    console.log({msg})
    
      // wrapper.style.alignItems = 'flex-start'; 

      const bubble = document.createElement('div');
      bubble.classList.add('message-bubble', isOwn ? 'own' : 'other');

      if (!isOwn) {
        const img = document.createElement('img');
        img.src = msg.sender?.avatarPath || '/img/default-avatar.png';
        img.style.width = '30px';
        img.style.height = '30px';
        img.style.borderRadius = '50%';
        bubble.appendChild(img);
      }

      const span = document.createElement('span');
      span.innerHTML = msg.text.replace(/@(\w+)/g, '<span class="mention">@$1</span>');
      bubble.appendChild(span);

      if (isOwn) {
        const img = document.createElement('img');
        img.src = "<%= user.avatar || '/img/default-avatar.png' %>";
        img.style.width = '30px';
        img.style.height = '30px';
        img.style.borderRadius = '50%';
        bubble.appendChild(img);
      }

      wrapper.appendChild(bubble);

      const timestamp = new Date(msg.createdAt).toLocaleTimeString([], {
        hour: '2-digit',
        minute: '2-digit'
      });

      const small = document.createElement('small');
      small.innerText = `${msg.sender?.name || 'Unknown'} • ${timestamp}`;
      small.style.textAlign = isOwn ? 'right' : 'left';
      wrapper.appendChild(small);

      const popup = document.createElement('div');
      popup.classList.add('reactions-popup');

      ['👍','❤️','😂'].forEach(emoji => {
        const btn = document.createElement('span');
        btn.classList.add('reaction-btn');
        btn.innerText = emoji;
        btn.addEventListener('click', () => {
          socket.emit('react-message', { roomId, messageId: msg._id, emoji });
        });
        popup.appendChild(btn);
      });

      wrapper.appendChild(popup);

      const display = document.createElement('div');
      display.classList.add('reactions-display');

      if (msg.reactions) {
        Object.entries(msg.reactions).forEach(([emoji, users]) => {
          const span = document.createElement('span');
          span.innerText = `${emoji} ${users.length}`;
          display.appendChild(span);
        });
      }

      wrapper.appendChild(display);

      

      return wrapper;
    }
  </script>

</body>
</html>

